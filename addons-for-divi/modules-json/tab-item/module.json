{
  "name": "divitorque/tab-item",
  "moduleClassName": "dtq_tab_item",
  "moduleOrderClassName": "dtq_tab_item",
  "title": "Tab",
  "titles": "Tabs",
  "moduleIcon": "divitorque/tab-item",
  "category": "child-module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "htmlAttributes": {}
        },
        "decoration": {
          "animation": {},
          "background": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "spacing": {},
          "transform": {},
          "transition": {},
          "disabledOn": {}
        }
      }
    },
    "title": {
      "type": "object",
      "selector": "{{selector}} .dtq-tabs__label-text",
      "elementType": "heading",
      "tagName": "span",
      "inlineEditor": "plainText",
      "attributes": {
        "class": "dtq-tabs__label-text"
      },
      "childrenSanitizer": "et_core_esc_previously",
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "priority": 10,
            "render": true,
            "attrName": "title.innerContent",
            "label": "Tab Label",
            "description": "The label shown on the tab button.",
            "component": {
              "type": "field",
              "name": "divi/text"
            },
            "features": {
              "sticky": false,
              "responsive": false,
              "hover": false,
              "dynamicContent": true
            }
          }
        }
      }
    },
    "content": {
      "type": "object",
      "selector": "{{selector}} .dtq-tabs__content",
      "elementType": "content",
      "attributes": {
        "class": "dtq-tabs__content"
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "priority": 20,
            "render": true,
            "attrName": "content.innerContent",
            "label": "Content",
            "description": "The content shown in this tab's panel.",
            "component": {
              "type": "field",
              "name": "divi/richtext"
            },
            "features": {
              "sticky": false,
              "responsive": false,
              "hover": false,
              "dynamicContent": true
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "content": {
      "subName": "content",
      "selectorSuffix": " .dtq-tabs__content"
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentMain": {
        "panel": "content",
        "priority": 10,
        "groupName": "contentMain",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Content"
          }
        }
      }
    }
  }
}