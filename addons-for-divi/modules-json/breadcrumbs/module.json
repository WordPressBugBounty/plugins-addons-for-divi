{
  "name": "divitorque/breadcrumbs",
  "moduleClassName": "dtq_breadcrumbs",
  "moduleOrderClassName": "dtq_breadcrumbs",
  "title": "Breadcrumbs",
  "titles": "Breadcrumbs",
  "moduleIcon": "divitorque/breadcrumbs",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "advanced": {
          "homeText": {
            "desktop": {
              "value": "Home"
            }
          },
          "separator": {
            "desktop": {
              "value": "›"
            }
          },
          "showHome": {
            "desktop": {
              "value": "on"
            }
          },
          "showCurrent": {
            "desktop": {
              "value": "on"
            }
          },
          "enableSchema": {
            "desktop": {
              "value": "on"
            }
          },
          "alignment": {
            "desktop": {
              "value": "left"
            }
          }
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "htmlAttributes": {},
          "homeText": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentMain",
              "attrName": "module.advanced.homeText",
              "label": "Home Text",
              "description": "Label for the home link.",
              "priority": 10,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/text"
              }
            }
          },
          "separator": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentMain",
              "attrName": "module.advanced.separator",
              "label": "Separator",
              "description": "Character shown between items (e.g. › / • | →).",
              "priority": 20,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/text"
              }
            }
          },
          "showHome": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentMain",
              "attrName": "module.advanced.showHome",
              "label": "Show Home Link",
              "description": "Show the home link at the start of the trail.",
              "priority": 30,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/toggle"
              }
            }
          },
          "showCurrent": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentMain",
              "attrName": "module.advanced.showCurrent",
              "label": "Show Current Page",
              "description": "Show the current page as the last item.",
              "priority": 40,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/toggle"
              }
            }
          },
          "enableSchema": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentMain",
              "attrName": "module.advanced.enableSchema",
              "label": "Output BreadcrumbList Schema",
              "description": "Add schema.org BreadcrumbList structured data for SEO.",
              "priority": 50,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/toggle"
              }
            }
          },
          "alignment": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designMain",
              "attrName": "module.advanced.alignment",
              "label": "Alignment",
              "description": "Horizontal alignment of the trail.",
              "priority": 5,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": true,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "left": {
                      "label": "Left"
                    },
                    "center": {
                      "label": "Center"
                    },
                    "right": {
                      "label": "Right"
                    }
                  }
                }
              }
            }
          },
          "linkColor": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designMain",
              "attrName": "module.advanced.linkColor",
              "label": "Link Color",
              "description": "Color of the breadcrumb links.",
              "priority": 20,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": true
              },
              "component": {
                "type": "field",
                "name": "divi/color-picker",
                "props": {
                  "isAlpha": true
                }
              }
            }
          },
          "currentColor": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designMain",
              "attrName": "module.advanced.currentColor",
              "label": "Current Page Color",
              "description": "Color of the current (last) item.",
              "priority": 30,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/color-picker",
                "props": {
                  "isAlpha": true
                }
              }
            }
          },
          "separatorColor": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designMain",
              "attrName": "module.advanced.separatorColor",
              "label": "Separator Color",
              "description": "Color of the separator character.",
              "priority": 40,
              "render": true,
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "type": "field",
                "name": "divi/color-picker",
                "props": {
                  "isAlpha": true
                }
              }
            }
          }
        },
        "decoration": {
          "animation": {},
          "background": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "overflow": {},
          "position": {},
          "scroll": {},
          "spacing": {},
          "sizing": {},
          "sticky": {},
          "transform": {},
          "transition": {},
          "zIndex": {},
          "disabledOn": {}
        }
      }
    },
    "text": {
      "type": "object",
      "selector": "{{selector}} .dtq-breadcrumbs",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "size": "15px",
                  "lineHeight": "1.6em"
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designMain",
              "priority": 10,
              "render": true,
              "component": {
                "name": "divi/font",
                "type": "group",
                "props": {
                  "grouped": false,
                  "fieldLabel": "Text",
                  "fields": {
                    "headingLevel": {
                      "render": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "link": {
      "subName": "link",
      "selectorSuffix": " .dtq-breadcrumbs__link"
    },
    "separator": {
      "subName": "separator",
      "selectorSuffix": " .dtq-breadcrumbs__sep"
    },
    "current": {
      "subName": "current",
      "selectorSuffix": " .dtq-breadcrumbs__current"
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentMain": {
        "panel": "content",
        "priority": 10,
        "groupName": "contentMain",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Breadcrumbs"
          }
        }
      },
      "designMain": {
        "panel": "design",
        "priority": 10,
        "groupName": "designMain",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Breadcrumbs"
          }
        }
      }
    }
  }
}